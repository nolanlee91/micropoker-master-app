# ── Frontend (Vite — bundled into the client) ────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Server-side (api/coach.js — set in Vercel project env, never bundled) ──
# GEMINI_API_KEY is required for the AI Coach.
# The coach endpoint also verifies the caller's Supabase session; it reuses
# SUPABASE_URL / SUPABASE_ANON_KEY, falling back to the VITE_* values above.
GEMINI_API_KEY=your_gemini_key_here
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here
#
# ── Coach anti-abuse caps (all OPTIONAL — sane defaults baked into coach.js) ──
# Per-user daily caps (counts EVERY call: analysis + follow-up + fix + debrief):
# COACH_CAP_ANON=2                 # anonymous (no login) — small demo taste
# COACH_CAP_FREE=3                 # signed-in free, steady (2nd coach-usage day onward)
# COACH_CAP_FREE_DAY1=8            # signed-in free, FIRST day USING the coach (activation wow)
# COACH_CAP_PRO=20                 # active Pro subscriber
# Per-IP cap — anonymous only; stops one device farming many throwaway anon accts:
# COACH_CAP_IP_ANON=8
# COACH_IP_SALT=some_random_string # salts the IP hash (defaults to SUPABASE_URL)
# Global daily circuit breaker across ALL users (hard 429 backstop). Raise as you
# grow; needs db/migration-2-anti-abuse.sql applied:
# COACH_GLOBAL_DAILY_CAP=3000

# ── Stripe (api/create-checkout-session.js + api/stripe-webhook.js) ──
# Server-side only — never bundled into the client. Use TEST keys while testing.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx          # from `stripe listen` or the Dashboard webhook
STRIPE_PRICE_MONTHLY=price_xxx           # Price id of the $9.99/mo recurring price
STRIPE_PRICE_ANNUAL=price_xxx            # Price id of the $83.99/yr recurring price
# Service-role key — lets the webhook write the subscriptions table (bypasses RLS).
# Find it in Supabase → Project Settings → API. KEEP SECRET (full DB access).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
